import tkinter as tk
import random

choices = ["Rock", "Paper", "Scissors"]

round_num = 1
player_score = 0
computer_score = 0
player_choice = ""

def start_round(choice):
    global player_choice

    if round_num <= 3:
        player_choice = choice
        countdown(3)

def countdown(sec):
    if sec > 0:
        result_label.config(text=f"Round {round_num}\nRevealing in {sec}...")
        root.after(1000, countdown, sec - 1)
    else:
        play_game()

def play_game():
    global round_num, player_score, computer_score

    computer_choice = random.choice(choices)

    if player_choice == computer_choice:
        result = "Draw!"
    elif (player_choice == "Rock" and computer_choice == "Scissors") or \
         (player_choice == "Paper" and computer_choice == "Rock") or \
         (player_choice == "Scissors" and computer_choice == "Paper"):
        result = "You Win!"
        player_score += 1
    else:
        result = "Computer Wins!"
        computer_score += 1

    result_label.config(
        text=f"Round {round_num}\n\n"
             f"Your Choice: {player_choice}\n"
             f"Computer Choice: {computer_choice}\n\n"
             f"{result}\n\n"
             f"Score\nYou: {player_score}  Computer: {computer_score}"
    )

    round_num += 1

    if round_num > 3:
        root.after(2000, show_final_result)

def show_final_result():
    if player_score > computer_score:
        final = "🎉 You Won the Match!"
    elif computer_score > player_score:
        final = "💻 Computer Won the Match!"
    else:
        final = "🤝 Match Draw!"

    result_label.config(
        text=f"FINAL RESULT\n\n"
             f"Your Score: {player_score}\n"
             f"Computer Score: {computer_score}\n\n"
             f"{final}"
    )

    rock_btn.config(state="disabled")
    paper_btn.config(state="disabled")
    scissors_btn.config(state="disabled")

# GUI
root = tk.Tk()
root.title("Rock Paper Scissors")
root.geometry("450x400")

title = tk.Label(root, text="Rock Paper Scissors - 3 Rounds",
                 font=("Arial", 16, "bold"))
title.pack(pady=10)

rock_btn = tk.Button(root, text="Rock", width=15,
                     command=lambda: start_round("Rock"))
rock_btn.pack(pady=5)

paper_btn = tk.Button(root, text="Paper", width=15,
                      command=lambda: start_round("Paper"))
paper_btn.pack(pady=5)

scissors_btn = tk.Button(root, text="Scissors", width=15,
                         command=lambda: start_round("Scissors"))
scissors_btn.pack(pady=5)

result_label = tk.Label(root, text="Choose Rock, Paper or Scissors",
                        font=("Arial", 12))
result_label.pack(pady=20)

root.mainloop()
